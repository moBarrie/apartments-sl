// Prisma schema for Sierra Leone Apartment Rental Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  RENTER
  LANDLORD
  ADMIN
}

enum PropertyType {
  STUDIO
  APARTMENT
  HOUSE
  VILLA
}

enum ListingStatus {
  PENDING
  ACTIVE
  INACTIVE
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  ORANGE_MONEY
  AFRICELL_MONEY
  CARD
}

enum SubscriptionTier {
  FREE
  PREMIUM
  ENTERPRISE
}

enum AmenityCategory {
  ESSENTIAL
  COMFORT
  SAFETY
  ENTERTAINMENT
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String
  phone         String?
  role          UserRole
  avatarUrl     String?   @map("avatar_url")
  isVerified    Boolean   @default(false) @map("is_verified")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  landlordProfile    LandlordProfile?
  apartments         Apartment[]
  bookings           Booking[]
  reviews            Review[]
  favorites          Favorite[]
  sentMessages       Message[] @relation("SentMessages")
  receivedMessages   Message[] @relation("ReceivedMessages")
  notifications      Notification[]

  @@map("users")
}

model LandlordProfile {
  id                    String            @id @default(uuid())
  userId                String            @unique @map("user_id")
  businessName          String?           @map("business_name")
  idVerificationUrl     String?           @map("id_verification_url")
  isVerified            Boolean           @default(false) @map("is_verified")
  totalProperties       Int               @default(0) @map("total_properties")
  rating                Decimal           @default(0.00) @db.Decimal(3, 2)
  subscriptionTier      SubscriptionTier  @default(FREE) @map("subscription_tier")
  subscriptionExpiresAt DateTime?         @map("subscription_expires_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("landlord_profiles")
}

model Apartment {
  id               String         @id @default(uuid())
  landlordId       String         @map("landlord_id")
  title            String
  description      String
  pricePerNight    Decimal        @map("price_per_night") @db.Decimal(10, 2)
  pricePerMonth    Decimal?       @map("price_per_month") @db.Decimal(10, 2)
  city             String
  neighborhood     String?
  address          String
  latitude         Decimal?       @db.Decimal(10, 8)
  longitude        Decimal?       @db.Decimal(11, 8)
  bedrooms         Int
  bathrooms        Int
  maxGuests        Int            @map("max_guests")
  propertyType     PropertyType   @map("property_type")
  squareMeters     Int?           @map("square_meters")
  isFeatured       Boolean        @default(false) @map("is_featured")
  featuredUntil    DateTime?      @map("featured_until")
  status           ListingStatus  @default(PENDING)
  viewsCount       Int            @default(0) @map("views_count")
  rating           Decimal        @default(0.00) @db.Decimal(3, 2)
  reviewCount      Int            @default(0) @map("review_count")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  // Relations
  landlord      User                  @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  images        ApartmentImage[]
  amenities     ApartmentAmenity[]
  bookings      Booking[]
  reviews       Review[]
  favorites     Favorite[]
  blockedDates  BlockedDate[]

  @@index([city])
  @@index([landlordId])
  @@index([status])
  @@index([pricePerNight])
  @@map("apartments")
}

model Amenity {
  id        String          @id @default(uuid())
  name      String          @unique
  icon      String?
  category  AmenityCategory

  // Relations
  apartments ApartmentAmenity[]

  @@map("amenities")
}

model ApartmentAmenity {
  apartmentId String @map("apartment_id")
  amenityId   String @map("amenity_id")

  // Relations
  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  amenity   Amenity   @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([apartmentId, amenityId])
  @@map("apartment_amenities")
}

model ApartmentImage {
  id           String   @id @default(uuid())
  apartmentId  String   @map("apartment_id")
  imageUrl     String   @map("image_url")
  isFeatured   Boolean  @default(false) @map("is_featured")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@map("apartment_images")
}

model Booking {
  id                 String        @id @default(uuid())
  apartmentId        String        @map("apartment_id")
  renterId           String        @map("renter_id")
  checkinDate        DateTime      @map("checkin_date") @db.Date
  checkoutDate       DateTime      @map("checkout_date") @db.Date
  guestsCount        Int           @map("guests_count")
  totalPrice         Decimal       @map("total_price") @db.Decimal(10, 2)
  platformFee        Decimal       @map("platform_fee") @db.Decimal(10, 2)
  serviceFee         Decimal       @map("service_fee") @db.Decimal(10, 2)
  status             BookingStatus @default(PENDING)
  specialRequests    String?       @map("special_requests")
  cancellationReason String?       @map("cancellation_reason")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  // Relations
  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  renter    User      @relation(fields: [renterId], references: [id], onDelete: Cascade)
  payment   Payment?
  review    Review?
  messages  Message[]

  @@index([apartmentId])
  @@index([renterId])
  @@index([checkinDate, checkoutDate])
  @@map("bookings")
}

model Payment {
  id            String        @id @default(uuid())
  bookingId     String        @unique @map("booking_id")
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("USD")
  paymentMethod PaymentMethod @map("payment_method")
  transactionId String?       @unique @map("transaction_id")
  status        PaymentStatus @default(PENDING)
  paymentDate   DateTime?     @map("payment_date")
  refundDate    DateTime?     @map("refund_date")
  createdAt     DateTime      @default(now()) @map("created_at")

  // Relations
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Review {
  id                String   @id @default(uuid())
  bookingId         String   @unique @map("booking_id")
  apartmentId       String   @map("apartment_id")
  reviewerId        String   @map("reviewer_id")
  rating            Int
  cleanlinessRating Int?     @map("cleanliness_rating")
  accuracyRating    Int?     @map("accuracy_rating")
  locationRating    Int?     @map("location_rating")
  valueRating       Int?     @map("value_rating")
  comment           String?
  landlordResponse  String?  @map("landlord_response")
  isVisible         Boolean  @default(true) @map("is_visible")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  reviewer  User      @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([apartmentId])
  @@map("reviews")
}

model Favorite {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  apartmentId String   @map("apartment_id")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@unique([userId, apartmentId])
  @@map("favorites")
}

model Message {
  id         String   @id @default(uuid())
  bookingId  String?  @map("booking_id")
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  message    String
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  booking  Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender   User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@map("messages")
}

model BlockedDate {
  id          String   @id @default(uuid())
  apartmentId String   @map("apartment_id")
  blockedDate DateTime @map("blocked_date") @db.Date
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@unique([apartmentId, blockedDate])
  @@map("blocked_dates")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}
